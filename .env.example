# Groq API Key (Get one at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# The path to the project folder REVI should analyze and work on
# Example: ./my_project or C:\path\to\project
FOLDER_PATH=./

# The LLM model to use (e.g., llama3-70b-8192, mixtral-8x7b-32768)
MODEL=llama3-70b-8192

# Docker Sandbox Settings
# Set to true if Docker is installed and you want to execute commands in a container
SANDBOX_ENABLED=false
SANDBOX_IMAGE=python:3.11-slim
