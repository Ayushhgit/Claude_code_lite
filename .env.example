# Provider Selection (groq or gemini)
PROVIDER=groq

# API Keys (Provide the one corresponding to your selected PROVIDER)
# Groq API Key (Get one at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (Get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# The path to the project folder REVI should analyze and work on
# Example: ./my_project or C:\path\to\project
FOLDER_PATH=./

# The LLM model to use (e.g., llama3-70b-8192 for groq, gemini-2.5-flash for gemini)
MODEL=llama3-70b-8192

# Docker Sandbox Settings
# Set to true if Docker is installed and you want to execute commands in a container
SANDBOX_ENABLED=false
SANDBOX_IMAGE=python:3.11-slim
