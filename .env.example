# ── Provider ──────────────────────────────────────────────────────────────────
# Options: groq | gemini
PROVIDER=groq

# ── API Keys ──────────────────────────────────────────────────────────────────
# Groq: https://console.groq.com/keys
#
# Option A — Multi-key pool (recommended for heavy usage)
# Add keys from separate Groq accounts. The agent automatically rotates to the
# next key when the current account's quota is exhausted. Up to 10 keys supported.
GROQ_API_KEY_1=your_groq_api_key_account_1_here
GROQ_API_KEY_2=your_groq_api_key_account_2_here
GROQ_API_KEY_3=your_groq_api_key_account_3_here
# GROQ_API_KEY_4=your_groq_api_key_account_4_here
# GROQ_API_KEY_5=your_groq_api_key_account_5_here
#
# Option B — Single key fallback (backward-compatible)
# Used if no numbered keys (GROQ_API_KEY_1 etc.) are found.
# GROQ_API_KEY=your_groq_api_key_here

# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Project Target ────────────────────────────────────────────────────────────
# Absolute or relative path to the folder REVI should work on
FOLDER_PATH=C:\Projects\Claude_code_lite\test

# ── Model Override (optional) ─────────────────────────────────────────────────
# Leave unset to use auto-routing across models based on task type (recommended).
# Set to a specific Groq model ID to pin all calls to that model.
# Use /model in the CLI to switch interactively at runtime.
# MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Gemini Model (only used when PROVIDER=gemini) ─────────────────────────────
GEMINI_MODEL=gemini-2.5-flash

# ── Sandbox (optional) ────────────────────────────────────────────────────────
# Set to true if Docker is installed and you want sandboxed command execution
SANDBOX_ENABLED=false
SANDBOX_IMAGE=python:3.11-slim

# ── GitHub Webhook (optional) ─────────────────────────────────────────────────
# Secret for verifying incoming GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
